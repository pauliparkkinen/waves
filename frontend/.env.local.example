# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Frontend URL
AUTH_URL=http://localhost:3002

# ── Auth provider ─────────────────────────────────────────────────────────────
# Set to "zitadel" or "keycloak"
NEXT_PUBLIC_AUTH_PROVIDER=zitadel

# ── Zitadel ───────────────────────────────────────────────────────────────────
# Create a "Web" application, enable "Code" flow with PKCE, and add
# http://localhost:3002/api/auth/callback/zitadel as a redirect URI.
ZITADEL_CLIENT_ID=
ZITADEL_ISSUER=http://localhost:3000

# ── Keycloak ──────────────────────────────────────────────────────────────────
# Create a "confidential" OpenID Connect client in your Keycloak realm and add
# http://localhost:3002/api/auth/callback/keycloak as a redirect URI.
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:8080/realms/myrealm

# ── Backend API ───────────────────────────────────────────────────────────────
# Start with: PORT=3001 pnpm dev  (from the backend/ directory)
BACKEND_URL=http://localhost:3000
