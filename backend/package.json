{
  "name": "waves-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build:rust": "cargo build --release --manifest-path rust-simulator/Cargo.toml",
    "build": "pnpm build:rust && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "simple-git-hooks": {
    "pre-commit": "cd backend && ./node_modules/.bin/lint-staged"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "pdfjs-dist": "^5.7.284",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.5",
    "@vitest/coverage-v8": "^2.1.9",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "xlsx": "^0.18.5"
  }
}
